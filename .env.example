# Discord Bot
DISCORD_TOKEN=

# ConoHa API 認証
CONOHA_USERNAME=
CONOHA_PASSWORD=
TENANT_ID=
# リージョン: tyo1（東京1）/ tyo2（東京2）/ sin1（シンガポール）
CONOHA_REGION=tyo1

# 操作対象サーバー
SERVER_ID=

# 自動停止通知を送るDiscordチャンネルID（数字）
